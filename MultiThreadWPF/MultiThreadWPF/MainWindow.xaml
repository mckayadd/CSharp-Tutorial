<Window x:Class="MultiThreadWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MultiThreadWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <StackPanel Margin="20">

            <Button Name="btnCalculate" Content="Calculate Robot's Route" Click="BtnCalculate_Click" Height="40" />

            <ProgressBar Name="pbStatus" IsIndeterminate="True" Height="10" Margin="0,10" Visibility="Collapsed" />

            <TextBlock Name="txtResult" Text="Status: Waiting..." Margin="0,10" FontSize="16"/>
            
        </StackPanel>
        
    </Grid>
</Window>
