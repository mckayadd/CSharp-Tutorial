<Window x:Class="RobotCubeWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RobotCubeWPF.ViewModels"
        Title="3D Cube" Height="600" Width="800">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    
    <Grid Background="#252525">
        <Viewport3D>
            <Viewport3D.Camera>
                <PerspectiveCamera Position="{Binding CameraPosition}" LookDirection="{Binding CameraLookDirection}" UpDirection="0, 1, 0" FieldOfView="45" />
            </Viewport3D.Camera>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="White" Direction="-1,-1,-1" />
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <GeometryModel3D>
                        <GeometryModel3D.Geometry>
                            <MeshGeometry3D Positions="{Binding CubePositions}"
                                            TriangleIndices="{Binding CubeIndices}"/>
                        </GeometryModel3D.Geometry>
                        <GeometryModel3D.Material>
                            <DiffuseMaterial Brush="{Binding CubeColor}"/>
                        </GeometryModel3D.Material>
                    </GeometryModel3D>
                </ModelVisual3D.Content>
            </ModelVisual3D>
        </Viewport3D>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20">

            <TextBlock Text="Cube Size (Scale)" Foreground="White" Margin="0,0,0,5"/>
            <Slider Minimum="0.1" 
                    Maximum="3.0" 
                    Value="{Binding Scale}" 
                    TickFrequency="0.1" 
                    IsSnapToTickEnabled="True" />

            <TextBlock Text="Camera Distance (Zoom)" Foreground="White" Margin="0,15,0,5"/>
            <Slider Minimum="2" 
                    Maximum="15" 
                    Value="{Binding CameraDistance}" />

            <Button Content="Change Color"
                    Margin="10"
                    Command="{Binding ChangeColorCommand}"
                    Padding="10,5"
                    Background="DimGray"
                    Foreground="White"/>

        </StackPanel>

    </Grid>
</Window>