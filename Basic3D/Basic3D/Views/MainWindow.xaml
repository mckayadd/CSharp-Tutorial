<Window x:Class="RobotCubeWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RobotCubeWPF.ViewModels"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="3D Cube Robot Sim" Height="600" Width="800">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Background="#252525">
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="MouseDown">
                <i:InvokeCommandAction Command="{Binding MouseDownCommand}" PassEventArgsToCommand="True"/>
            </i:EventTrigger>
            <i:EventTrigger EventName="MouseMove">
                <i:InvokeCommandAction Command="{Binding MouseMoveCommand}" PassEventArgsToCommand="True"/>
            </i:EventTrigger>
            <i:EventTrigger EventName="MouseUp">
                <i:InvokeCommandAction Command="{Binding MouseUpCommand}" PassEventArgsToCommand="True"/>
            </i:EventTrigger>
        </i:Interaction.Triggers>

        <Viewport3D>
            <Viewport3D.Camera>
                <PerspectiveCamera Position="{Binding CameraPosition}" 
                                   LookDirection="{Binding CameraLookDirection}" 
                                   UpDirection="0, 1, 0" 
                                   FieldOfView="45" />
            </Viewport3D.Camera>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="White" Direction="-1,-1,-1" />
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <GeometryModel3D>
                        <GeometryModel3D.Geometry>
                            <MeshGeometry3D Positions="-5,-1.1,-5 5,-1.1,-5 5,-1.1,5 -5,-1.1,5"
                                            TriangleIndices="0 2 1 0 3 2" 
                                            TextureCoordinates="0,0 10,0 10,10 0,10"/>
                        </GeometryModel3D.Geometry>
                        <GeometryModel3D.Material>
                            <MaterialGroup>
                                <DiffuseMaterial Brush="Transparent" />
                                <EmissiveMaterial>
                                    <EmissiveMaterial.Brush>
                                        <VisualBrush TileMode="Tile" Viewport="0,0,0.1,0.1">
                                            <VisualBrush.Visual>
                                                <Grid Width="100" Height="100">
                                                    <Border BorderBrush="Gray" BorderThickness="1" Background="#10FFFFFF"/>
                                                </Grid>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </EmissiveMaterial.Brush>
                                </EmissiveMaterial>
                            </MaterialGroup>
                        </GeometryModel3D.Material>
                    </GeometryModel3D>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <ModelVisual3D>
                <ModelVisual3D.Transform>
                    <Transform3DGroup>
                        <RotateTransform3D>
                            <RotateTransform3D.Rotation>
                                <AxisAngleRotation3D Axis="1,0,0" Angle="{Binding RotationX}" />
                            </RotateTransform3D.Rotation>
                        </RotateTransform3D>
                        <RotateTransform3D>
                            <RotateTransform3D.Rotation>
                                <AxisAngleRotation3D Axis="0,1,0" Angle="{Binding RotationY}" />
                            </RotateTransform3D.Rotation>
                        </RotateTransform3D>

                        <TranslateTransform3D OffsetY="1.5" />
                    </Transform3DGroup>
                </ModelVisual3D.Transform>

                <ModelVisual3D.Content>
                    <GeometryModel3D>
                        <GeometryModel3D.Geometry>
                            <MeshGeometry3D Positions="{Binding CubePositions}" TriangleIndices="{Binding CubeIndices}"/>
                        </GeometryModel3D.Geometry>
                        <GeometryModel3D.Material>
                            <DiffuseMaterial Brush="{Binding CubeColor}"/>
                        </GeometryModel3D.Material>
                    </GeometryModel3D>
                </ModelVisual3D.Content>
            </ModelVisual3D>

        </Viewport3D>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20" Width="180">
            <TextBlock Text="Cube Size (Scale)" Foreground="White" Margin="0,0,0,5"/>
            <Slider Minimum="0.1" Maximum="3.0" Value="{Binding Scale}" 
                    TickFrequency="0.1" IsSnapToTickEnabled="True" />
            <TextBlock Text="{Binding Scale, StringFormat={}{0:F1}}" Foreground="OrangeRed" Margin="0,0,0,15" FontWeight="Bold"/>

            <TextBlock Text="Camera Distance (Zoom)" Foreground="White" Margin="0,10,0,5"/>
            <Slider Minimum="2" Maximum="15" Value="{Binding CameraDistance}" />
            <TextBlock Text="{Binding CameraDistance, StringFormat={}{0:F1}}" Foreground="OrangeRed" Margin="0,0,0,15" FontWeight="Bold"/>

            <Button Content="Change Color" 
                    Command="{Binding ChangeColorCommand}"
                    Padding="10,5" Margin="0,10,0,0"
                    Background="DimGray" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>